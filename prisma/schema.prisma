generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AssessmentStatus {
  DRAFT
  READY_TO_SUBMIT
  COMPLETED
}

enum Gender {
  MALE
  FEMALE
}

enum AssessmentGoal {
  LOSE_WEIGHT
  GAIN_WEIGHT
  MAINTAIN_WEIGHT
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model User {
  id                 String              @id @default(uuid()) @db.Uuid
  anonymousTokenHash String              @unique @map("anonymous_token_hash")
  assessmentSessions AssessmentSession[]
  subscriptions      Subscription[]
  paymentEvents      PaymentEvent[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@map("users")
}

model AssessmentSession {
  id            String             @id @default(uuid()) @db.Uuid
  userId        String             @map("user_id") @db.Uuid
  status        AssessmentStatus   @default(DRAFT)
  currentStep   Int                @default(0) @map("current_step")
  version       Int                @default(0)
  submittedAt   DateTime?          @map("submitted_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile       AssessmentProfile?
  result        AssessmentResult?
  stepEvents    StepEvent[]
  paymentEvents PaymentEvent[]

  @@index([userId, status])
  @@map("assessment_sessions")
}

model AssessmentProfile {
  id                  String            @id @default(uuid()) @db.Uuid
  assessmentSessionId String            @unique @map("assessment_session_id") @db.Uuid
  gender              Gender?
  goal                AssessmentGoal?
  age                 Int?
  heightCm            Decimal?          @map("height_cm") @db.Decimal(6, 2)
  weightKg            Decimal?          @map("weight_kg") @db.Decimal(6, 2)
  targetWeightKg      Decimal?          @map("target_weight_kg") @db.Decimal(6, 2)
  activityLevel       ActivityLevel?    @map("activity_level")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  assessmentSession   AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)

  @@map("assessment_profiles")
}

model AssessmentResult {
  id                  String            @id @default(uuid()) @db.Uuid
  assessmentSessionId String            @unique @map("assessment_session_id") @db.Uuid
  bmi                 Decimal           @db.Decimal(5, 2)
  bmiCategory         String            @map("bmi_category")
  recommendedCalories Int               @map("recommended_calories")
  targetDate          DateTime          @map("target_date")
  projectionCurve     Json              @map("projection_curve")
  predictionCapped    Boolean           @default(false) @map("prediction_capped")
  algorithmVersion    String            @map("algorithm_version")
  calculatedAt        DateTime          @default(now()) @map("calculated_at")
  assessmentSession   AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)

  @@map("assessment_results")
}

model Subscription {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  status    SubscriptionStatus @default(INACTIVE)
  source    String             @default("mock")
  startsAt  DateTime?          @map("starts_at")
  expiresAt DateTime?          @map("expires_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt])
  @@map("subscriptions")
}

model PaymentEvent {
  id                  String            @id @default(uuid()) @db.Uuid
  userId              String            @map("user_id") @db.Uuid
  assessmentSessionId String            @map("assessment_session_id") @db.Uuid
  idempotencyKey      String            @unique @map("idempotency_key")
  status              PaymentStatus     @default(PENDING)
  payload             Json?
  processedAt         DateTime?         @map("processed_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentSession   AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([assessmentSessionId])
  @@map("payment_events")
}

model StepEvent {
  id                  String            @id @default(uuid()) @db.Uuid
  assessmentSessionId String            @map("assessment_session_id") @db.Uuid
  stepKey             String            @map("step_key")
  requestId           String            @map("request_id")
  payload             Json
  payloadHash         String            @map("payload_hash")
  clientVersion       Int               @map("client_version")
  createdAt           DateTime          @default(now()) @map("created_at")
  assessmentSession   AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)

  @@unique([assessmentSessionId, requestId])
  @@index([assessmentSessionId, stepKey])
  @@map("step_events")
}
